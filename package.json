{
  "name": "evofork",
  "version": "0.4.2",
  "private": true,
  "description": "Open-source framework for building self-evolving applications.",
  "type": "module",
  "packageManager": "pnpm@10.32.1",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10.0.0"
  },
  "scripts": {
    "build": "TURBO_TELEMETRY_DISABLED=1 turbo build --concurrency=8",
    "dev": "TURBO_TELEMETRY_DISABLED=1 turbo dev --parallel",
    "test": "TURBO_TELEMETRY_DISABLED=1 turbo test --concurrency=6",
    "typecheck": "TURBO_TELEMETRY_DISABLED=1 turbo typecheck --concurrency=8",
    "lint": "TURBO_TELEMETRY_DISABLED=1 turbo lint --concurrency=8",
    "verify": "pnpm build && pnpm test && pnpm typecheck && pnpm lint && pnpm evo manifest validate && pnpm evo eval report --surface pricing.hero --changed-file apps/demo-nextjs/src/app/pricing/PricingHero.tsx",
    "evo": "node packages/cli/dist/index.js"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "tsx": "^4.19.2",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
