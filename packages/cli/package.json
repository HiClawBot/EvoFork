{
  "name": "@evofork/cli",
  "version": "0.3.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "evo": "dist/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/index.ts",
    "test": "vitest run --passWithNoTests",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@evofork/branch-registry": "workspace:*",
    "@evofork/db": "workspace:*",
    "@evofork/eval-gate": "workspace:*",
    "@evofork/insight-worker": "workspace:*",
    "@evofork/manifest-parser": "workspace:*",
    "@evofork/patch-agent": "workspace:*",
    "@evofork/policy-engine": "workspace:*",
    "@evofork/rollout-observer": "workspace:*",
    "@evofork/router": "workspace:*"
  }
}
